## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build logs
*.log

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image build caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on interactive terminals
$RECYCLE.BIN/

# Compiler bridge (Roslyn)
*.roslynca*

# Others
ClientDocumentPortal.Web/bin/
ClientDocumentPortal.Web/obj/
ClientDocumentPortal.Infrastructure/bin/
ClientDocumentPortal.Infrastructure/obj/
ClientDocumentPortal.Application/bin/
ClientDocumentPortal.Application/obj/
ClientDocumentPortal.Domain/bin/
ClientDocumentPortal.Domain/obj/

# Rider
.idea/

# Dotnet CLI
project.lock.json
project.fragment.lock.json
artifacts/

# Web
node_modules/
.npm/

# Entity Framework
sql/

# Operating System Files
.DS_Store
.AppleDouble
.LSOverride
Icon
Network Trash Folder
Temporary Items
.apdisk
